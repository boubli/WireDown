# WireDown Configuration
# Copy this file to .env and fill in the values.

# Flask secret key — auto-generated at runtime if left empty
FLASK_SECRET_KEY=

# CORS allowed origins — default * for LAN appliances.
# Set to specific origin (e.g. http://10.0.0.50:8080) to lock down.
CORS_ORIGINS=*

# SSH honeypot port (default 2222)
SSH_HONEYPOT_PORT=2222

# DNS sinkhole port (default 5353)
DNS_SINKHOLE_PORT=5353

# ESP32 serial port for auto-flashing (auto-detected if empty)
ESP32_PORT=

# SOC Dashboard Admin Credentials (for authenticating at /admin)
ADMIN_USERNAME=wiredown
ADMIN_PASSWORD=admin
